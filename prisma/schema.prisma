// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  SEASONAL
}

enum PayType {
  HOURLY
  SALARY
}

enum EmployeeStatus {
  ACTIVE
  LEAVE_OF_ABSENCE
  TERMINATED
}

enum ChangeAction {
  CREATE
  UPDATE
  DELETE
}

model Employee {
  id               String                 @id @default(cuid())
  employeeId       String?                @unique
  firstName        String
  lastName         String
  preferredName    String?
  email            String?
  phone            String?
  company          String?
  department       String?
  roleTitle        String?
  roleFamily       String?
  site             String?
  manager          String?
  employmentType   EmploymentType?
  payType          PayType?
  status           EmployeeStatus         @default(ACTIVE)
  hireDate         DateTime?
  terminationDate  DateTime?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  reviewDismissals ReviewIssueDismissal[]
}

// A reviewer's decision that a data-completeness issue flagged on the review
// page is fine as-is for one employee. Soft flag only: a row here hides that
// one issue from the active review view — the employee record itself is never
// changed, mirroring how terminated employees are marked rather than deleted.
// `checkKey` is the `key` of a REVIEW_CHECKS entry in app/review/query.ts.
// The cascade removes dismissals with their employee; the audit trail lives in
// EmployeeChangeLog, which each dismissal also writes to.
model ReviewIssueDismissal {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String
  checkKey    String
  dismissedBy String?
  dismissedAt DateTime @default(now())

  @@unique([employeeId, checkKey])
}

// Append-only audit trail of every create/update/delete on an Employee.
// `employeeId` deliberately has no relation/foreign key to Employee so that
// deleting an employee never cascades into (or blocks) removing their history.
model EmployeeChangeLog {
  id         String       @id @default(cuid())
  employeeId String
  action     ChangeAction
  // CREATE: the initial field values. UPDATE: only changed fields as
  // { field: { from, to } }. DELETE: a marker.
  changes    Json
  // Nullable for now; populated with the signed-in user once auth lands.
  changedBy  String?
  createdAt  DateTime     @default(now())

  @@index([employeeId, createdAt])
}
